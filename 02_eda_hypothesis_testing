,"ax.set_ylabel('Acceptance rate (%)', fontsize=12)\n","ax.set_ylim(0, 100)\n","ax.axhline(y=df['offer_accepted'].mean()*100,\n","           color='gray', linestyle='--', linewidth=1,\n","           label=f'Overall avg: {df[\"offer_accepted\"].mean():.0%}')\n","ax.legend()\n","plt.tight_layout()\n","plt.savefig('/content/drive/MyDrive/chart_seniority_acceptance.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","print(\"✅ Chart 2 saved to Drive\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":624},"id":"QnyBp74H5hak","executionInfo":{"status":"ok","timestamp":1780648126866,"user_tz":-120,"elapsed":462,"user":{"displayName":"solomon obiechina","userId":"05889942517651912685"}},"outputId":"2b13699b-fbf4-4927-df8c-827df22b3ffc"},"execution_count":11,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["✅ Chart 2 saved to Drive\n"]}]},{"cell_type":"code","source":["numeric_cols = [\n","    'salary_increase_pct', 'seniority_jump', 'months_in_current_role',\n","    'process_length_days', 'hiring_manager_sentiment', 'recruiter_sentiment',\n","    'candidate_nps', 'interview_score', 'employer_brand_score',\n","    'response_time_hours', 'competing_offers', 'remote_policy_match',\n","    'relocation_required', 'visa_required', 'stage_drop_risk', 'offer_accepted'\n","]\n","\n","corr = df[numeric_cols].corr()\n","\n","fig, ax = plt.subplots(figsize=(13, 10))\n","mask = np.triu(np.ones_like(corr, dtype=bool))\n","\n","sns.heatmap(corr, mask=mask, annot=True, fmt='.2f',\n","            cmap='RdYlGn', center=0, vmin=-1, vmax=1,\n","            square=True, linewidths=0.5,\n","            annot_kws={'size': 8}, ax=ax)\n","\n","ax.set_title('Feature correlation heatmap', fontsize=14, pad=15)\n","plt.xticks(rotation=45, ha='right', fontsize=9)\n","plt.yticks(rotation=0, fontsize=9)\n","plt.tight_layout()\n","plt.savefig('/content/drive/MyDrive/chart_correlation_heatmap.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","print(\"✅ Chart 3 saved to Drive\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"SrKQn2fQ5rUa","executionInfo":{"status":"ok","timestamp":1780648197655,"user_tz":-120,"elapsed":640,"user":{"displayName":"solomon obiechina","userId":"05889942517651912685"}},"outputId":"8796556a-d85d-4f63-ce25-b6688a1b6507"},"execution_count":13,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1300x1000 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["✅ Chart 3 saved to Drive\n"]}]},{"cell_type":"code","source":["print(\"=\" * 60)\n","print(\"HYPOTHESIS TESTING RESULTS\")\n","print(\"=\" * 60)\n","\n","# H1 — Salary lift (t-test)\n","high_sal = df[df['salary_increase_pct'] > 20]['offer_accepted']\n","low_sal  = df[df['salary_increase_pct'] < 5]['offer_accepted']\n","t1, p1   = stats.ttest_ind(high_sal, low_sal)\n","print(f\"\\nH1 — Salary lift predicts acceptance\")\n","print(f\"  Accept rate >20% lift:  {high_sal.mean():.1%}\")\n","print(f\"  Accept rate <5% lift:   {low_sal.mean():.1%}\")\n","print(f\"  t = {t1:.2f}, p = {p1:.4f} {'✅ SUPPORTED' if p1 < 0.05 else '❌ NOT SUPPORTED'}\")\n","\n","# H2 — Competing offers (chi-square)\n","ct2 = pd.crosstab(df['competing_offers'], df['offer_accepted'])\n","chi2, p2, _, _ = stats.chi2_contingency(ct2)\n","no_comp  = df[df['competing_offers']==0]['offer_accepted'].mean()\n","yes_comp = df[df['competing_offers']==1]['offer_accepted'].mean()\n","print(f\"\\nH2 — Competing offers reduce acceptance\")\n","print(f\"  Accept rate (no competing offer):  {no_comp:.1%}\")\n","print(f\"  Accept rate (has competing offer): {yes_comp:.1%}\")\n","print(f\"  χ² = {chi2:.2f}, p = {p2:.4f} {'✅ SUPPORTED' if p2 < 0.05 else '❌ NOT SUPPORTED'}\")\n","\n","# H3 — Process length (ANOVA)\n","fast   = df[df['process_length_days'] < 21]['offer_accepted']\n","med